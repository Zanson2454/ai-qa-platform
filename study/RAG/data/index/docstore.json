\n\uf06c 5 \u5e74\u4ee5\u4e0a\u6d4b\u8bd5\u7ecf\u9a8c\uff0c\u627f\u62c5\u8fc7\u591a\u4e2a\u5927\u578b\u9879\u76ee\u7684\u6d4b\u8bd5\u8d1f\u8d23\u4eba\uff0c\u6709 5 \u4eba\u7684\u56e2\u961f\u7ba1\u7406\u7ecf\u9a8c\n\uf06c \u719f\u6089\u8f6f\u4ef6\u5f00\u53d1\u548c\u6d4b\u8bd5\u6d41\u7a0b\uff0c\u80fd\u81ea\u4e0b\u800c\u4e0a\u4e3b\u52a8\u63a8\u8fdb\u9879\u76ee\u7684\u6d41\u7a0b\n\uf06c \u5177\u6709\u8f83\u597d\u7684\u4e1a\u52a1\u9700\u6c42\u5206\u6790\u80fd\u529b\uff0c\u80fd\u6839\u636e\u9700\u6c42\u8fdb\u884c\u6d4b\u8bd5\u8bbe\u8ba1\u53ca\u7528\u4f8b\u7684\u7f16\u5199\n\uf06c \u5177\u5907\u591a\u7aef\u6d4b\u8bd5\u7ecf\u9a8c\uff0cWeb\u3001H5\u3001APP \u7aef\n\uf06c \u719f\u6089 Robotframework\u3001selenium\u3001Appium \u6846\u67b6\n\uf06c \u5177\u5907\u63a5\u53e3\u81ea\u52a8\u5316\u6d4b\u8bd5(python)\u3001\u6027\u80fd\u6d4b\u8bd5(PTS)\u3001BI \u7b49\u5b9e\u9645\u6d4b\u8bd5\u7ecf\u9a8c\n\uf06c \u719f\u7ec3\u638c\u63e1\u65e5\u5e38\u6293\u5305\u5de5\u5177 fiddler\u3001Charles \u7684\u4f7f\u7528\n\uf06c \u81ea\u9a71\u52a8&\u5b66\u4e60\u80fd\u529b\u5f3a\uff0c\u903b\u8f91\u601d\u7ef4\u80fd\u529b\u5f3a\u3001\u601d\u7ef4\u6d3b\u8dc3\uff0c\u9002\u5e94\u80fd\u529b\u5f3a\uff0c\u80fd\u8f83\u5feb\u901f\u7684\u9002\u5e94\u65b0\u4e8b\u7269\uff1b\n\uf06c \u6709\u8f83\u597d\u7684\u6c9f\u901a\u534f\u4f5c\u80fd\u529b\uff0c\u80fd\u4e0e\u5ba2\u6237\u3001\u4ea7\u54c1\u3001\u9879\u76ee\u7ecf\u7406\u3001\u7814\u53d1\u3001\u6d4b\u8bd5\u5185\u90e8\u4fdd\u6301\u826f\u597d\u7684\u6c9f\u901a\uff0c\u4ee5\u4fdd\u969c\u8f83\u597d\u7684\u56e2\n\u961f\u534f\u4f5c\n\u671f\u671b\u804c\u4f4d\n\u6d4b\u8bd5\u5de5\u7a0b\u5e08 \u676d\u5dde \u9762\u8bae \u65b0\u96f6\u552e\u00b7\u4f01\u4e1a\u670d\u52a1\u00b7O2O\n\u5de5\u4f5c\u7ecf\u5386\n\u676d\u5dde\u7aef\u70b9\u7f51\u7edc\u79d1\u6280\u6709\u9650\u516c\u53f8(\u963f\u91cc\u4e91-\u7aef\u70b9\u79d1\u6280)\n\u6d4b\u8bd5\u5f00\u53d1 | \u6d4b\u8bd5\u90e8\u95e8 2016.06\u2014\u81f3\u4eca\n\u5185\u5bb9\uff1a\u4f5c\u4e3a\u9879\u76ee\u7684 PTM \u63a8\u8fdb\u53ca\u6267\u884c\u6d4b\u8bd5\u5de5\u4f5c\uff0c\u5305\u62ec\u6d4b\u8bd5\u8ba1\u5212\uff0c\u6d4b\u8bd5\u65b9\u6848\uff0c\u529f\u80fd/\u63a5\u53e3/\u6027\u80fd\u6d4b\u8bd5\u53ca\u62a5\u544a\u4ea7\u51fa\uff0c\u9879\n\u76ee\u4ea4\u4ed8\u9a8c\u6536\u652f\u6301\uff0c\u5e76\u63a8\u8fdb UAT \u51c6\u5165\u6807\u51c6\u3001\u9879\u76ee\u53d1\u5e03\u8ba1\u5212\u8bc4\u5ba1\u3001\u9879\u76ee\u6668\u4f1a\u98ce\u9669\u53cd\u9988\u3001\u7248\u672c\u53d1\u5e03\u540e\u9879\u76ee\u5185\u90e8\u590d\u76d8\u7b49\n\u5de5\u4f5c\uff0c\u4e0d\u65ad\u63d0\u5347\u9879\u76ee\u7ec4\u7814\u53d1\u8d28\u91cf\u610f\u8bc6\u548c\u6d4b\u8bd5\u7b56\u7565\n\u4e1a\u7ee9\uff1a1. \u5168\u9762\u8d1f\u8d23\u516c\u53f8\u96f6\u552e\u7ebf\u6807\u6746\u9879\u76ee-\u65b0\u534e\u4e66\u5e97\u7f51\u4e0a\u5546\u57ce\u7684\u6d4b\u8bd5\u5de5\u4f5c\uff0c\u6db5\u76d6\u6574\u4e2a\u8f6f\u4ef6\u5f00\u53d1\u751f\u547d\u5468\u671f,\u987a\u5229\u5b8c\u6210\n\u4e86\u591a\u8fed\u4ee3\u7684\u4e0a\u7ebf\uff0c\u5ba2\u6237\u6ee1\u610f\u5ea6\u8f83\u597d\uff1b\n2. \u5bf9\u96f6\u552e\u4e1a\u52a1\u719f\u6089\uff0c\u534f\u52a9\u96f6\u552e\u5f00\u53d1\u53ca\u5916\u5305\u6d4b\u8bd5\u540c\u5b66\u7406\u6e05\u65b0\u534e\u4e66\u5e97\u4e1a\u52a1\u903b\u8f91\n3. \u4ea7\u51fa\u6027\u80fd\u4e13\u9879\u6d4b\u8bd5\u767d\u76ae\u4e66\uff0c\u5e76\u6307\u5bfc\u5176\u4ed6\u9879\u76ee\u6d4b\u8bd5\u540c\u5b66\u5b8c\u6210\u57fa\u7840\u538b\u6d4b\u5de5\u4f5c\n\u676d\u5dde\u9500\u51a0\n\u6d4b\u8bd5\u5de5\u7a0b\u5e08 | \u6d4b\u8bd5\u90e8\u95e8 2015\u20142016.06\n\u5185\u5bb9\uff1a1. \u8d1f\u8d23\u516c\u53f8\u4ea7\u54c1\u9500\u51a0 CLub \u53ca\u9500\u51a0\u52a9\u624b\u7684\u6d4b\u8bd5\u5de5\u4f5c\uff0c\u5305\u62ec web \u7aef\u548c\u79fb\u52a8\u7aef ios&android\n2. \u4f7f\u7528 robot framework \u81ea\u52a8\u5316\u6846\u67b6\u8fdb\u884c\u63a5\u53e3\u81ea\u52a8\u5316\n\u4e1a\u7ee9\uff1a1. \u8d1f\u8d23\u9500\u51a0 Club \u4ece 0 \u5230 1\uff0c\u5e76\u987a\u5229\u4e0a\u7ebf", "mimetype": "text/plain", "start_char_idx": 0, "end_char_idx": 912, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "ccf79b66-2fd6-44a7-af7f-cb9d2c6d5483": {"__data__": {"id_": "ccf79b66-2fd6-44a7-af7f-cb9d2c6d5483", "embedding": null, "metadata": {"page_label": "2", "file_name": "\u7aef\u70b9-\u7ae0\u6602.pdf", "file_path": "/var/folders/4d/xwxwsk692w343tqr1nvqx4y00000gn/T/tmp9462nbti/\u7aef\u70b9-\u7ae0\u6602.pdf", "file_type": "application/pdf", "file_size": 1008034, "creation_date": "2026-04-21", "last_modified_date": "2026-04-21"}, "excluded_embed_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "excluded_llm_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "relationships": {"1": {"node_id": "5300d20b-bc76-4bad-bc9b-810cc20fed36", "node_type": "4", "metadata": {"page_label": "2", "file_name": "\u7aef\u70b9-\u7ae0\u6602.pdf", "file_path": "/var/folders/4d/xwxwsk692w343tqr1nvqx4y00000gn/T/tmp9462nbti/\u7aef\u70b9-\u7ae0\u6602.pdf", "file_type": "application/pdf", "file_size": 1008034, "creation_date": "2026-04-21", "last_modified_date": "2026-04-21"}, "hash": "7d1fa57966369112a45570d8519b755f612ab7fff8ce7f0af55cec607cac1e9a", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "\u7b80\u5386\u6765\u81ea\uff1aBOSS \u76f4\u8058\n2. \u8d1f\u8d23\u9500\u51a0\u52a9\u624b\u4ece 0 \u5230 1\uff0c\u5e76\u987a\u5229\u4e0a\u7ebf\n\u91d1\u534e\u5b87\u8054\u7f51\u7edc\u79d1\u6280\u6709\u9650\u516c\u53f8\nweb \u6d4b\u8bd5 | \u6d4b\u8bd5 2013\u20142015\n\u5185\u5bb9\uff1a1. \u529f\u80fd\u6d4b\u8bd5\n2. \u82f1\u6587\u9700\u6c42\u7ffb\u8bd1\n3. JSON \u914d\u7f6e\u6587\u4ef6\u7f16\u5199\n\u4e1a\u7ee9\uff1a\u987a\u5229\u652f\u6301\u9879\u76ee\u591a\u4e2a\u7248\u672c\u7684\u8fed\u4ee3\u5e76\u4ea4\u4ed8\n\u9879\u76ee\u7ecf\u5386\n\u65b0\u534e\u4e66\u5e97\u7535\u5b50\u5546\u57ce\n\u6d4b\u8bd5 PTM 2018.05\u2014\u81f3\u4eca\n\u63cf\u8ff0\uff1a\u627f\u63a5\u65b0\u534e\u4e66\u5e97\u7f51\u4e0a\u5546\u57ce\u7684\u642d\u5efa\uff0c\u4e3a\u5ba2\u6237\u6253\u9020\u7eb5\u6a2a\u4ea4\u7ec7\u7684\u7ecf\u8425\u4f53\u7cfb\uff1a\n\u7eb5\u5411\u4e0a\uff0c\u4ece\u5355\u5e97\u72ec\u7acb\u8fd0\u8425\u5230\u603b\u5e97\u5e73\u53f0\u5316\u7ba1\u7406\u8d4b\u80fd\n\u6a2a\u5411\u4e0a\uff0c\u4ece\u5355\u4e00\u7684\u4e66\u7c4d\u9500\u552e\u6269\u5c55\u5230\u6d88\u8d39\u8005\u7684\u5168\u65b9\u4f4d\u60a6\u8bfb\u751f\u6001\uff0c\u5305\u62ec\u4ece\u7eb8\u8d28\u4e66\u7c4d\u5230\u65b0\u5a92\u4f53\u7684\u5ef6\u4f38\uff0c\u4ece\u4e66\u5e97\u5230\u56fe\u4e66\n\u9986\u7684\u5ef6\u4f38\uff0c\u5b9e\u7269\u5546\u54c1\u5230\u865a\u62df\u5546\u54c1\u7684\u5ef6\u4f38\uff0c\u5982\u7535\u5b50\u4e66\uff0c\u97f3\u89c6\u9891\u7b49\u6587\u6559\u751f\u6001\uff1b\u5728\u5185\u5bb9\uff0c\u573a\u6240\u4e0a\u5b9e\u73b0\u878d\u5408\uff0c\u4e92\u52a8\u548c\u4e2a\n\u6027\u5316\uff1b\n\u540c\u65f6\uff0c\u7ed3\u5408\u65b0\u96f6\u552e\u7684\u7406\u5ff5\uff0c\u5728\u4f1a\u5458\u8425\u9500\uff0c\u79ef\u5206\u5151\u6362\uff0c\u4f18\u60e0\u4fc3\u9500\uff0c\u5408\u4f5c\u4f19\u4f34\u5f15\u6d41\u7b49\u65b9\u9762\u8fdb\u884c\u8fd0\u8425\u65b9\u5f0f\u7684\u521b\u65b0\uff0c\u5b9e\n\u73b0\u7ebf\u4e0a\uff0c\u7ebf\u4e0b\u8fd0\u8425\u7684\u4ea4\u4e92\u548c\u591a\u6837\u5316\u3002\u7cfb\u7edf\u5305\u542b\u7528\u6237\u4e2d\u5fc3\u3001\u5546\u54c1\u4e2d\u5fc3\u3001\u5e93\u5b58\u4e2d\u5fc3\u3001\u4fc3\u9500\u4e2d\u5fc3\u3001\u4ea4\u6613\u4e2d\u5fc3\u3001\u7ed3\u7b97\u4e2d\n\u5fc3\u7b49\u7b49\u591a\u79cd\u80fd\u529b\uff0c\u9664\u4e86\u652f\u6301\u81ea\u8425\u7535\u5546\u4e1a\u52a1\uff0c\u8fd8\u652f\u6301\u7ebf\u4e0b\u95e8\u5e97 ERP\u3001\u56fe\u4e66\u7cfb\u7edf\u3001\u7269\u6d41\u516c\u53f8\u3001\u4e91\u53d1\u7968\u7b49\u5916\u90e8\u7cfb\u7edf\uff0c\n\u5b9e\u73b0\u4f01\u4e1a\u751a\u81f3\u6574\u4e2a\u4ea7\u4e1a\u94fe\u7684\u534f\u4f5c\u8054\u901a\n\u4e1a\u7ee9\uff1a1. \u5b8c\u6210\u65b0\u534e\u4e66\u4e66\u5e97\u7535\u5b50\u5546\u57ce\u4e00\u671f\u4ece 0~1 \u642d\u5efa\u6210\u529f\u5e76\u987a\u5229\u4ea4\u4ed8\uff0c\u9879\u76ee\u4f5c\u4e3a\u516c\u53f8\u96f6\u552e\u7ebf\u7684\u6807\u6746\u9879\u76ee\u4e0d\u65ad\u63a8\u8350\n2. \u65b0\u534e\u4e66\u5e97\u4e8c\u671f\u9879\u76ee\u7684 10 \u6b21 Spring \u5df2\u7ecf\u987a\u5229\u6267\u884c\u6b21\uff0c\u5ba2\u6237\u6ee1\u610f\u5ea6\u5e73\u7a33\u63d0\u5347\n3. \u652f\u6301\u5927\u6d41\u91cf\u6d3b\u52a8\u7684\u6027\u80fd\u538b\u6d4b-\u77ac\u65f6 10W \u5e76\u53d1\n\u9879\u76ee\u94fe\u63a5\uff1ahttps://www.xhsd.com/\n\u5b9d\u80dc\u8fd0\u52a8\u5546\u57ce\n\u6d4b\u8bd5\u8d1f\u8d23\u4eba 2017.05\u20142017.10\n\u63cf\u8ff0\uff1a\u5168\u6e20\u9053\u96f6\u552e\u52a9\u7406\u4f01\u4e1a\u6570\u5b57\u5316\u8f6c\u578b\n1. \u539f\u751f\u5f00\u53d1 APP\uff0c\u6574\u5408\u793e\u7fa4\u3001\u6d3b\u52a8\u3001\u8d2d\u7269\u4e3a\u4e00\u4f53\n2. \u5b8c\u6574\u7684\u7535\u5546\u8425\u9500\u6d3b\u52a8\u3001\u7535\u5b50\u5238\u529f\u80fd\u5b8c\u5584\u3001\u81ea\u5b9a\u4e49\u9875\u9762\u88c5\u4fee\u7cfb\u7edf\n3. \u7edf\u4e00\u7684\u5546\u54c1\u4e2d\u5fc3\u3001\u8ba2\u5355\u4e2d\u5fc3\u3001\u5e93\u5b58\u4e2d\u5fc3\n4. \u4e1a\u52a1\u4e2d\u53f0\u89e3\u51b3\u65b9\u6848\n\u4e1a\u7ee9\uff1a1. \u8d1f\u8d23\u5b9d\u80dc\u8fd0\u52a8\u5546\u57ce\u4e00\u671f\u4ece 0~1 \u642d\u5efa\u7684\u6d4b\u8bd5\u5e76\u987a\u5229\u4e0a\u7ebf\n2. \u652f\u6301\u591a\u8fed\u4ee3\u7248\u672c\u4e0a\u7ebf\n\u9879\u76ee\u94fe\u63a5\uff1ahttp://mall.yysports.com/\n\u5c81\u5b9d\u767e\u8d27\n\u6d4b\u8bd5\u8d1f\u8d23\u4eba 2016.06\u20142017.04\n\u63cf\u8ff0\uff1a", "mimetype": "text/plain", "start_char_idx": 0, "end_char_idx": 876, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "78b9fe16-b509-4ab7-a417-c5ba30b21b54": {"__data__": {"id_": "78b9fe16-b509-4ab7-a417-c5ba30b21b54", "embedding": null, "metadata": {"page_label": "3", "file_name": "\u7aef\u70b9-\u7ae0\u6602.pdf", "file_path": "/var/folders/4d/xwxwsk692w343tqr1nvqx4y00000gn/T/tmp9462nbti/\u7aef\u70b9-\u7ae0\u6602.pdf", "file_type": "application/pdf", "file_size": 1008034, "cr