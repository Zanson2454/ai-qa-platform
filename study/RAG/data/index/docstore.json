ar/folders/4d/xwxwsk692w343tqr1nvqx4y00000gn/T/tmp9462nbti/\u7aef\u70b9-\u7ae0\u6602.pdf", "file_type": "application/pdf", "file_size": 1008034, "creation_date": "2026-04-21", "last_modified_date": "2026-04-21"}}, "20680bfd-242d-4b59-b61c-cbafad1b8b88": {"node_ids": ["78b9fe16-b509-4ab7-a417-c5ba30b21b54"], "metadata": {"page_label": "3", "file_name": "\u7aef\u70b9-\u7ae0\u6602.pdf", "file_path": "/var/folders/4d/xwxwsk692w343tqr1nvqx4y00000gn/T/tmp9462nbti/\u7aef\u70b9-\u7ae0\u6602.pdf", "file_type": "application/pdf", "file_size": 1008034, "creation_date": "2026-04-21", "last_modified_date": "2026-04-21"}}}, "docstore/data": {"082585d1-1198-45e2-a0a3-894a23dd0ba9": {"__data__": {"id_": "082585d1-1198-45e2-a0a3-894a23dd0ba9", "embedding": null, "metadata": {"path": "/var/folders/4d/xwxwsk692w343tqr1nvqx4y00000gn/T/tmp9462nbti/\u6d4b\u8bd5\u5546\u54c1.jpg"}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "6247fde7-c398-4d88-b29b-3d7a8c36b539", "node_type": "4", "metadata": {"path": "/var/folders/4d/xwxwsk692w343tqr1nvqx4y00000gn/T/tmp9462nbti/\u6d4b\u8bd5\u5546\u54c1.jpg"}, "hash": "58f0aa2ff2aa6b9be165e7ba1965ae3fbedd1c75acd9a6779066db584e41df75", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "\u8fd9\u5f20\u56fe\u7247\u4ee5**\u7eaf\u767d\u8272**\u4e3a\u80cc\u666f\uff0c\u4e3b\u4f53\u662f\u56db\u4e2a**\u9ed1\u8272\u6c49\u5b57**\uff0c\u91c7\u7528**2\u00d72\u7684\u65b9\u9635\u5f0f\u6392\u5217**\uff08\u5373\u4e24\u884c\u4e24\u5217\uff09\uff0c\u6574\u4f53\u8bbe\u8ba1\u7b80\u6d01\u4e14\u5bcc\u6709\u89c6\u89c9\u79e9\u5e8f\u611f\u3002\n\n---\n\n### \u4e00\u3001\u6587\u5b57\u5185\u5bb9\u4e0e\u5e03\u5c40\n- **\u7b2c\u4e00\u884c**\uff1a\u4ece\u5de6\u81f3\u53f3\u4e3a\u201c\u6d4b\u201d\u548c\u201c\u8bd5\u201d\uff1b\n- **\u7b2c\u4e8c\u884c**\uff1a\u4ece\u5de6\u81f3\u53f3\u4e3a\u201c\u5546\u201d\u548c\u201c\u54c1\u201d\uff1b\n- \u56db\u5b57\u5171\u540c\u7ec4\u6210\u8bcd\u8bed\u201c**\u6d4b\u8bd5\u5546\u54c1**\u201d\uff0c\u8868\u8fbe\u660e\u786e\uff0c\u5e38\u7528\u4e8e\u5546\u54c1\u68c0\u6d4b\u3001\u6837\u54c1\u8bd5\u7528\u7b49\u573a\u666f\u3002\n\n---\n\n### \u4e8c\u3001\u5b57\u4f53\u98ce\u683c\u4e0e\u7ec6\u8282\n\u5b57\u4f53\u4e3a**\u827a\u672f\u5316\u4e66\u6cd5\u98ce\u683c**\uff0c\u517c\u5177\u4f20\u7edf\u6c49\u5b57\u7ed3\u6784\u4e0e\u73b0\u4ee3\u8bbe\u8ba1\u611f\uff0c\u5177\u6709\u4ee5\u4e0b\u7279\u70b9\uff1a\n\n1. **\u7b14\u753b\u7c97\u7ec6\u53d8\u5316\u660e\u663e**  \n   - \u6a2a\u753b\u8f83\u7ec6\uff0c\u7ad6\u753b\u8f83\u7c97\uff0c\u5f62\u6210\u89c6\u89c9\u5bf9\u6bd4\uff1b\n   - \u90e8\u5206\u7b14\u753b\u672b\u7aef\u5e26\u6709\u88c5\u9970\u6027\u6536\u7b14\uff08\u5982\u201c\u6d4b\u201d\u7684\u4e09\u70b9\u6c34\u3001\u201c\u8bd5\u201d\u7684\u8a00\u5b57\u65c1\uff09\uff0c\u5c55\u73b0\u51fa\u4e66\u6cd5\u97f5\u5473\u3002\n\n2. **\u7ed3\u6784\u65b9\u6b63\u3001\u5bf9\u79f0**  \n   - \u6bcf\u4e2a\u5b57\u90fd\u4fdd\u6301\u4e86\u6c49\u5b57\u7684\u65b9\u5757\u7ed3\u6784\uff0c\u6574\u4f53\u6392\u5217\u6574\u9f50\uff0c\u89c6\u89c9\u4e0a\u7a33\u5b9a\u3001\u6b63\u5f0f\uff1b\n   - \u4f8b\u5982\u201c\u54c1\u201d\u5b57\u7531\u4e09\u4e2a\u201c\u53e3\u201d\u7ec4\u6210\uff0c\u4e0a\u4e0b\u6392\u5217\u89c4\u6574\uff0c\u6bcf\u4e2a\u201c\u53e3\u201d\u90fd\u5448\u6b63\u65b9\u5f62\uff0c\u7ebf\u6761\u5e72\u51c0\u5229\u843d\u3002\n\n3. **\u7ec6\u8282\u5904\u7406\u7cbe\u81f4**  \n   - \u201c\u6d4b\u201d\u5b57\u7684\u4e09\u70b9\u6c34\u5199\u6cd5\u7565\u5e26\u5f27\u5ea6\uff0c\u4e0d\u5446\u677f\uff1b\n   - \u201c\u5546\u201d\u5b57\u4e2d\u95f4\u90e8\u5206\uff08\u201c\u518f\u201d\uff09\u7ed3\u6784\u6e05\u6670\uff0c\u7b14\u753b\u8f6c\u6298\u5904\u6709\u68f1\u89d2\uff0c\u4f53\u73b0\u8bbe\u8ba1\u611f\uff1b\n   - \u201c\u8bd5\u201d\u5b57\u53f3\u4fa7\u201c\u5f0f\u201d\u7684\u201c\u5f0b\u201d\u90e8\u7b14\u753b\u7b80\u6d01\u6709\u529b\uff0c\u7b26\u5408\u73b0\u4ee3\u5ba1\u7f8e\u3002\n\n---\n\n### \u4e09\u3001\u6574\u4f53\u89c6\u89c9\u6548\u679c\n- **\u8272\u5f69\u5bf9\u6bd4\u5f3a\u70c8**\uff1a\u9ed1\u5b57\u767d\u5e95\uff0c\u6e05\u6670\u6613\u8bfb\uff0c\u9002\u5408\u7528\u4e8e\u6807\u8bc6\u3001\u6807\u7b7e\u7b49\u9700\u8981\u9ad8\u8fa8\u8bc6\u5ea6\u7684\u573a\u5408\uff1b\n- **\u98ce\u683c\u6b63\u5f0f\u7b80\u6d01**\uff1a\u6ca1\u6709\u591a\u4f59\u88c5\u9970\uff0c\u7a81\u51fa\u4fe1\u606f\u4f20\u8fbe\uff0c\u9002\u7528\u4e8e\u5546\u4e1a\u573a\u666f\u4e2d\u7684\u201c\u6d4b\u8bd5\u5546\u54c1\u201d\u6807\u8bc6\u3001\u6837\u54c1\u6807\u7b7e\u6216\u5185\u90e8\u6d41\u7a0b\u6307\u793a\uff1b\n- **\u7a7a\u95f4\u611f\u826f\u597d**\uff1a\u6587\u5b57\u95f4\u8ddd\u9002\u4e2d\uff0c\u7559\u767d\u5145\u8db3\uff0c\u907f\u514d\u62e5\u6324\u611f\uff0c\u7ed9\u4eba\u4e13\u4e1a\u3001\u6e05\u723d\u7684\u5370\u8c61\u3002\n\n---\n\n### \u56db\u3001\u53ef\u80fd\u7528\u9014\n\u8be5\u56fe\u50cf\u5f88\u53ef\u80fd\u662f\u7528\u4e8e**\u5546\u54c1\u6d4b\u8bd5\u9636\u6bb5\u7684\u6807\u8bc6**\uff0c\u4f8b\u5982\u5728\u7535\u5546\u5e73\u53f0\u3001\u8d28\u68c0\u5b9e\u9a8c\u5ba4\u6216\u4ea7\u54c1\u5f00\u53d1\u8fc7\u7a0b\u4e2d\uff0c\u7528\u4e8e\u533a\u5206\u201c\u6b63\u5728\u6d4b\u8bd5\u7684\u5546\u54c1\u201d\u4e0e\u6b63\u5f0f\u4e0a\u5e02\u5546\u54c1\uff0c\u5177\u6709\u660e\u786e\u7684\u529f\u80fd\u6027\u4e0e\u6307\u793a\u6027\u3002\n\n---\n\n\u603b\u7ed3\u6765\u8bf4\uff0c\u8fd9\u662f\u4e00\u5f20**\u8bbe\u8ba1\u7cbe\u826f\u3001\u4fe1\u606f\u660e\u786e\u3001\u98ce\u683c\u7b80\u7ea6**\u7684\u6587\u5b57\u56fe\u50cf\uff0c\u65e2\u4fdd\u7559\u4e86\u6c49\u5b57\u7684\u4f20\u7edf\u7f8e\u611f\uff0c\u53c8\u878d\u5165\u4e86\u73b0\u4ee3\u8bbe\u8ba1\u8bed\u8a00\uff0c\u9002\u7528\u4e8e\u591a\u79cd\u5546\u4e1a\u4e0e\u6280\u672f\u573a\u666f\u3002", "mimetype": "text/plain", "start_char_idx": 0, "end_char_idx": 877, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "0804d1da-ee66-4c2a-8350-f3c3b75e8792": {"__data__": {"id_": "0804d1da-ee66-4c2a-8350-f3c3b75e8792", "embedding": null, "metadata": {"path": "/var/folders/4d/xwxwsk692w343tqr1nvqx4y00000gn/T/tmp9462nbti/\u5fae\u4fe1\u56fe\u7247_2025-06-21_160634_464.jpg"}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "b423c71d-5839-4200-8b1a-5c66a3eec3f0", "node_type": "4", "metadata": {"path": "/var/folders/4d/xwxwsk692w343tqr1nvqx4y00000gn/T/tmp9462nbti/\u5fae\u4fe1\u56fe\u7247_2025-06-21_160634_464.jpg"}, "hash": "4ee8d33c113aaf7b6c37848cab48e8dbbedc0bb5e0173650d590b69862d5641d", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "\u8fd9\u5f20\u56fe\u7247\u5448\u73b0\u7684\u662f\u4e00\u4f4d\u7537\u6027\u4eba\u7269\u7684\u6b63\u9762\u534a\u8eab\u7167\uff0c\u6574\u4f53\u753b\u9762\u7b80\u6d01\u5e72\u51c0\uff0c\u80cc\u666f\u4e3a\u7eaf\u767d\u8272\uff0c\u7a81\u51fa\u4eba\u7269\u4e3b\u4f53\u3002\u4ee5\u4e0b\u662f\u8be6\u7ec6\u63cf\u8ff0\uff1a\n\n---\n\n### **\u4eba\u7269\u4e3b\u4f53**\n- **\u53d1\u578b**\uff1a\u9ed1\u8272\u77ed\u53d1\uff0c\u9020\u578b\u6574\u9f50\u5229\u843d\uff0c\u53d1\u4e1d\u84ec\u677e\u6709\u5c42\u6b21\u611f\uff0c\u663e\u5f97\u7cbe\u795e\u5e72\u7ec3\u3002\n- **\u9762\u90e8\u7279\u5f81**\uff1a\n  - \u4f69\u6234\u4e00\u526f**\u91d1\u5c5e\u7ec6\u6846\u773c\u955c**\uff0c\u955c\u6846\u989c\u8272\u4e3a\u6df1\u8272\uff08\u63a5\u8fd1\u9ed1\u8272\u6216\u6df1\u7070\u8272\uff09\uff0c\u8bbe\u8ba1\u7b80\u7ea6\uff0c\u8d34\u5408\u9762\u90e8\u8f6e\u5ed3\u3002\n  - \u9762\u90e8\u8868\u60c5\u81ea\u7136\u5e73\u548c\uff0c\u5634\u5507\u8f7b\u95ed\uff0c\u795e\u6001\u6c89\u7a33\uff0c\u65e0\u660e\u663e\u60c5\u7eea\u6ce2\u52a8\u3002\n  - \u5149\u7ebf\u5747\u5300\u67d4\u548c\uff0c\u91c7\u7528\u6b63\u9762\u6253\u5149\uff0c\u9762\u90e8\u7ec6\u8282\u6e05\u6670\uff0c\u65e0\u660e\u663e\u9634\u5f71\uff0c\u6574\u4f53\u663e\u5f97\u6b63\u5f0f\u4e14\u81ea\u7136\u3002\n- **\u7a7f\u7740**\uff1a\u8eab\u7a7f\u4e00\u4ef6**\u7eaf\u767d\u8272\u5706\u9886T\u6064**\uff0c\u6b3e\u5f0f\u7b80\u7ea6\u5927\u65b9\uff0c\u8863\u9886\u5e73\u6574\uff0c\u65e0\u591a\u4f59\u88c5\u9970\u3002\n\n---\n\n### **\u753b\u9762\u7ec6\u8282**\n- **\u80cc\u666f**\uff1a\u7eaf\u767d\u8272\u80cc\u666f\uff0c\u65e0\u4efb\u4f55\u5e72\u6270\u5143\u7d20\uff0c\u7a81\u51fa\u4eba\u7269\u4e3b\u4f53\uff0c\u8425\u9020\u51fa\u7b80\u6d01\u3001\u4e13\u4e1a\u7684\u89c6\u89c9\u6548\u679c\u3002\n- **\u6587\u5b57\u6807\u8bc6**\uff1a\u56fe\u50cf\u53f3\u4e0b\u89d2\u6709\u201c**\u6296\u97f3 AI\u5199\u771f**\u201d\u7684\u6587\u5b57\u6c34\u5370\uff0c\u8868\u660e\u8be5\u56fe\u50cf\u662f\u7531\u6296\u97f3\u5e73\u53f0\u7684AI\u6280\u672f\u751f\u6210\u7684\u5199\u771f\u7c7b\u56fe\u50cf\u3002\n\n---\n\n### **\u6574\u4f53\u98ce\u683c**\n\u753b\u9762\u98ce\u683c\u504f\u5411**\u8bc1\u4ef6\u7167\u6216\u804c\u4e1a\u5f62\u8c61\u7167**\uff0c\u5149\u7ebf\u5747\u5300\u3001\u6784\u56fe\u7b80\u6d01\uff0c\u5f3a\u8c03\u4eba\u7269\u7684\u81ea\u7136\u72b6\u6001\u4e0e\u4e13\u4e1a\u611f\u3002AI\u751f\u6210\u7684\u75d5\u8ff9\u4f53\u73b0\u5728\u7ec6\u8282\u7684\u5b8c\u7f8e\u5ea6\uff08\u5982\u80cc\u666f\u7eaf\u51c0\u3001\u5149\u7ebf\u5747\u5300\uff09\uff0c\u4f46\u6574\u4f53\u4ecd\u4fdd\u7559\u771f\u5b9e\u611f\u3002\n\n---\n\n\u8fd9\u5f20\u56fe\u7247\u901a\u8fc7\u7b80\u6d01\u7684\u80cc\u666f\u3001\u6e05\u6670\u7684\u9762\u90e8\u7ec6\u8282\u548c\u81ea\u7136\u7684\u795e\u6001\uff0c\u4f20\u9012\u51fa\u4e00\u79cd\u6c89\u7a33\u3001\u4e13\u4e1a\u7684\u5f62\u8c61\uff0c\u9002\u5408\u4f5c\u4e3a\u4e2a\u4eba\u5f62\u8c61\u5c55\u793a\u6216\u793e\u4ea4\u5e73\u53f0\u5934\u50cf\u4f7f\u7528\u3002", "mimetype": "text/plain", "start_char_idx": 0, "end_char_idx": 585, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "3876c3c2-279f-4f56-ab30-3b3b8d2d8c8f": {"__data__": {"id_": "3876c3c2-279f-4f56-ab30-3b3b8d2d8c8f", "embedding": null, "metadata": {"file_name": "\u963f\u91cc\u4e91-\u7aef\u70b9-\u7ae0\u6602.docx", "file_path": "/var/folders/4d/xwxwsk692w343tqr1nvqx4y00000gn/T/tmp9462nbti/\u963f\u91cc\u4e91-\u7aef\u70b9-\u7ae0\u6602.docx", "file_type": "application/vnd.openxmlformats-officedocument.wordprocessingml.document", "file_size": 76028, "creation_date": "2026-04-21", "last_modified_date": "2026-04-21"}, "excluded_embed_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "excluded_llm_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "relationships": {"1": {"node_id": "b2be0a23-9762-4c66-b70c-3a961f3f879e", "node_type": "4", "metadata": {"file_name": "\u963f\u91cc\u4e91-\u7aef\u70b9-\u7ae0\u6602.docx", "file_path": "/var/folders/4d/xwxwsk692w343tqr1nvqx4y00000gn/T/tmp9462nbti/\u963f\u91cc\u4e91-\u7aef\u70b9-\u7ae0\u6602.docx", "file_type": "application/vnd.openxmlformats-officedocument.wordprocessingml.document", "file_size": 76028, "creation_date": "2026-04-21", "last_modified_date": "2026-04-21"}, "hash": "4a6af148a135abbb9097b77b1b72c73c63454206cb08bf5b8df924ab3ec7a381", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "e057b933-bf3f-4e9f-80f7-cf30d0c5e8d4", "node_type": "1", "metadata": {}, "hash": "ea2f94c63af2022a0cf6fc35f335cbfcd4cb9d55e01ad962cc6e7524cdbf26e3", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "_______\u4e1a\u4e1a\u4e1a\u4e1a B\u53e3SS\u76f4\u8058\n\n\n\n\u7ae0\u6602\n\n27 \u5c81     |   \u7537     |   \u672c\u79d1     |    6 \u5e74\u7ecf\u9a8c  15167972454      |     zhangang.26@163.com\n\n\n\n  \u4e2a\u4eba\u4f18\u52bf\n\n     5 \u5e74\u4ee5\u4e0a\u6d4b\u8bd5\u7ecf\u9a8c \uff0c\u627f\u62c5\u8fc7\u591a\u4e2a\u5927\u578b\u9879\u76ee\u7684\u6d4b\u8bd5\u8d1f\u8d23\u4eba \uff0c\u6709 5 \u4eba\u7684\u56e2\u961f\u7ba1\u7406\u7ecf\u9a8c\n\n    \u719f\u6089\u8f6f\u4ef6\u5f00\u53d1\u548c\u6d4b\u8bd5\u6d41\u7a0b\uff0c \u80fd\u81ea\u4e0b\u800c\u4e0a\u4e3b\u52a8\u63a8\u8fdb\u9879\u76ee\u7684\u6d41\u7a0b\n\n    \u5177\u6709\u8f83\u597d\u7684\u4e1a\u52a1\u9700\u6c42\u5206\u6790\u80fd\u529b\uff0c \u80fd\u6839\u636e\u9700\u6c42\u8fdb\u884c\u6d4b\u8bd5\u8bbe\u8ba1\u53ca\u7528\u4f8b\u7684\u7f16\u5199\n\n    \u5177\u5907\u591a\u7aef\u6d4b\u8bd5\u7ecf\u9a8c \uff0cWeb\u3001H5\u3001APP \u7aef\n\n    \u719f\u6089 Robotframework\u3001 selenium\u3001Appium \u6846\u67b6\n\n    \u5177\u5907\u63a5\u53e3\u81ea\u52a8\u5316\u6d4b\u8bd5(python)\u3001 \u6027\u80fd\u6d4b\u8bd5(PTS)\u3001BI \u7b49\u5b9e\u9645\u6d4b\u8bd5\u7ecf\u9a8c\n\n    \u719f\u7ec3\u638c\u63e1\u65e5\u5e38\u6293\u5305\u5de5\u5177 fiddler\u3001Charles \u7684\u4f7f\u7528\n\n    \u81ea\u9a71\u52a8&\u5b66\u4e60\u80fd\u529b\u5f3a\uff0c\u903b\u8f91\u601d\u7ef4\u80fd\u529b\u5f3a\u3001 \u601d\u7ef4\u6d3b\u8dc3 \uff0c\u9002\u5e94\u80fd\u529b\u5f3a \uff0c\u80fd\u8f83\u5feb\u901f\u7684\u9002\u5e94\u65b0\u4e8b\u7269\uff1b\n\n    \u6709\u8f83\u597d\u7684\u6c9f\u901a\u534f\u4f5c\u80fd\u529b \uff0c\u80fd\u4e0e\u5ba2\u6237\u3001\u4ea7\u54c1\u3001 \u9879\u76ee\u7ecf\u7406\u3001\u7814\u53d1\u3001\u6d4b\u8bd5\u5185\u90e8\u4fdd\u6301\u826f\u597d\u7684\u6c9f\u901a \uff0c \u4ee5\u4fdd\u969c\u8f83\u597d\u7684\u56e2 \u961f\u534f\u4f5c\n\n\n\n  \u671f\u671b\u804c\u4f4d\n\n\u6d4b\u8bd5\u5de5\u7a0b\u5e08   \u676d\u5dde   \u9762\u8bae   \u65b0\u96f6\u552e \u00b7\u4f01\u4e1a\u670d\u52a1 \u00b7O2O\n\n\n\n  \u5de5\u4f5c\u7ecf\u5386\n\n\u676d\u5dde\u7aef\u70b9\u7f51\u7edc\u79d1\u6280\u6709\u9650\u516c\u53f8(\u963f\u91cc\u4e91-\u7aef\u70b9\u79d1\u6280)\n\n\u6d4b\u8bd5\u5f00\u53d1  | \u6d4b\u8bd5\u90e8\u95e8                                                                               2016.06\u2014\u81f3\u4eca\n\n\u5185\u5bb9\uff1a \u4f5c\u4e3a\u9879\u76ee\u7684 PTM \u63a8\u8fdb\u53ca\u6267\u884c\u6d4b\u8bd5\u5de5\u4f5c\uff0c\u5305\u62ec\u6d4b\u8bd5\u8ba1\u5212\uff0c\u6d4b\u8bd5\u65b9\u6848\uff0c\u529f\u80fd/\u63a5\u53e3/\u6027\u80fd\u6d4b\u8bd5\u53ca\u62a5\u544a\u4ea7\u51fa \uff0c\u9879 \u76ee\u4ea4\u4ed8\u9a8c\u6536\u652f\u6301\uff0c\u5e76\u63a8\u8fdb UAT \u51c6\u5165\u6807\u51c6\u3001 \u9879\u76ee\u53d1\u5e03\u8ba1\u5212\u8bc4\u5ba1\u3001 \u9879\u76ee\u6668\u4f1a\u98ce\u9669\u53cd\u9988\u3001\u7248\u672c\u53d1\u5e03\u540e\u9879\u76ee\u5185\u90e8\u590d\u76d8\u7b49 \u5de5\u4f5c \uff0c\u4e0d\u65ad\u63d0\u5347\u9879\u76ee\u7ec4\u7814\u53d1\u8d28\u91cf\u610f\u8bc6\u548c\u6d4b\u8bd5\u7b56\u7565\n\n\u4e1a\u7ee9\uff1a 1.  \u5168\u9762\u8d1f\u8d23\u516c\u53f8\u96f6\u552e\u7ebf\u6807\u6746\u9879\u76ee-\u65b0\u534e\u4e66\u5e97\u7f51\u4e0a\u5546\u57ce\u7684\u6d4b\u8bd5\u5de5\u4f5c \uff0c\u6db5\u76d6\u6574\u4e2a\u8f6f\u4ef6\u5f00\u53d1\u751f\u547d\u5468\u671f,\u987a\u5229\u5b8c\u6210 \u4e86\u591a\u8fed\u4ee3\u7684\u4e0a\u7ebf\uff0c\u5ba2\u6237\u6ee1\u610f\u5ea6\u8f83\u597d\uff1b\n\n2.  \u5bf9\u96f6\u552e\u4e1a\u52a1\u719f\u6089\uff0c\u534f\u52a9\u96f6\u552e\u5f00\u53d1\u53ca\u5916\u5305\u6d4b\u8bd5\u540c\u5b66\u7406\u6e05\u65b0\u534e\u4e66\u5e97\u4e1a\u52a1\u903b\u8f91\n\n3.  \u4ea7\u51fa\u6027\u80fd\u4e13\u9879\u6d4b\u8bd5\u767d\u76ae\u4e66\uff0c\u5e76\u6307\u5bfc\u5176\u4ed6\u9879\u76ee\u6d4b\u8bd5\u540c\u5b66\u5b8c\u6210\u57fa\u7840\u538b\u6d4b\u5de5\u4f5c\n\n\n\n\u676d\u5dde\u9500\u51a0\n\n\u6d4b\u8bd5\u5de5\u7a0b\u5e08  | \u6d4b\u8bd5\u90e8\u95e8                                                                            2015\u20142016.06\n\n\u5185\u5bb9\uff1a 1.  \u8d1f\u8d23\u516c\u53f8\u4ea7\u54c1\u9500\u51a0 CLub \u53ca\u9500\u51a0\u52a9\u624b\u7684\u6d4b\u8bd5\u5de5\u4f5c \uff0c\u5305\u62ec web \u7aef\u548c\u79fb\u52a8\u7aef ios&android\n\n\n\n2.  \u4f7f\u7528 robot framework  \u81ea\u52a8\u5316\u6846\u67b6\u8fdb\u884c\u63a5\u53e3\u81ea\u52a8\u5316\n\n\u4e1a\u7ee9\uff1a 1.  \u8d1f\u8d23\u9500\u51a0 Club \u4ece 0 \u5230 1 \uff0c\u5e76\u987a\u5229\u4e0a\u7ebf\n\n\u7b80\u5386\u6765\u81ea\uff1a BOSS \u76f4\u8058", "mimetype": "text/plain", "start_char_idx": 0, "end_char_idx": 1220, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "e057b933-bf3f-4e9f-80f7-cf30d0c5e8d4": {"__data__": {"id_": "e057b933-bf3f-4e9f-80f7-cf30d0c5e8d4", "embedding": null, "metadata": {"file_name": "\u963f\u91cc\u4e91-\u7aef